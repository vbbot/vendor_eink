on init
    # Linear brightness slider — E-Ink frontlight range is too small for the HLG perceptual curve.
    # With this set, slider 0-100% maps directly to hardware 0-80 with no dead zone at the bottom.
    setprop sys.brightness.disable_gamma_conversion true

service vendor.eink /system/bin/hw/vendor.vbbot.eink-service
    class main
    user system
    group system
    oneshot
    disabled

on property:sys.boot_completed=1
    start vendor.eink
